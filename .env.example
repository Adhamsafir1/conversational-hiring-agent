# Groq (primary) — comma-separated for key rotation
GROQ_API_KEYS=your_groq_key_1,your_groq_key_2
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Gemini (fallback) — comma-separated for key rotation
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# Retries when providers return 429
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=2.0
ENABLE_RETRIEVAL_FALLBACK=true
